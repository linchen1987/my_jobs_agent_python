# OpenAI Compatible API 配置
OPENAI_API_KEY=your_api_key_here
OPENAI_API_ENDPOINT=https://api.openai.com/v1
OPENAI_MODEL_ID=gpt-4

# 日志级别配置
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 存储配置
# 存储类型: local (本地文件系统) 或 s3 (S3 兼容存储)
STORAGE_TYPE=local
# 存储根路径 (本地存储为文件系统路径，S3 存储为 key 前缀)
STORAGE_ROOT_PATH=.data

# S3 存储配置 (仅当 STORAGE_TYPE=s3 时需要)
# S3 存储桶名称
S3_BUCKET=your-bucket-name
# S3 端点 URL (AWS S3 可不设置；兼容服务如 MinIO、Cloudflare R2、阿里云 OSS 等需要设置)
# 注意：可以省略 https:// 前缀，程序会自动添加
# 示例： oss-cn-beijing.aliyuncs.com 或 https://oss-cn-beijing.aliyuncs.com
S3_ENDPOINT_URL=
# AWS Access Key ID
S3_ACCESS_KEY_ID=
# AWS Secret Access Key
S3_SECRET_ACCESS_KEY=
# AWS 区域 (默认 auto，某些兼容服务需要特定区域)
S3_REGION=auto

# Telegram 通知配置 (可选)
# 是否启用 Telegram 通知 (true/false，默认 false)
TELEGRAM_ENABLED=false
# Telegram Bot Token，从 @BotFather 获取
TELEGRAM_BOT_TOKEN=
# Telegram Chat ID，接收通知的对话 ID
TELEGRAM_CHAT_ID=

# 抓取请求配置
# 详情页请求间隔秒数 (默认3.0)
FETCH_DETAIL_DELAY=3.0
